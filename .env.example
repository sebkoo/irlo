# Irlo server configuration — EXAMPLE ONLY, no real values.
# Copy to .env for local development. The Runtime section is zod-parsed by the
# server (C16); Datastores back the docker-compose dev env (C19); the rest
# documents the 12-factor contract for later stages (see ADR-0003).
# Payments keys are ALWAYS test-mode/sandbox — never commit live credentials.

# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Datastores (docker-compose dev env, C19) ---
DATABASE_URL=postgres://irlo:irlo@localhost:5432/irlo_dev
REDIS_URL=redis://localhost:6379

# --- Stripe (test mode only; see ADR-0004) ---
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- App Store Server API v2 (sandbox; see ADR-0004) ---
APP_STORE_ISSUER_ID=00000000-0000-0000-0000-000000000000
APP_STORE_KEY_ID=PLACEHOLDER
APP_STORE_PRIVATE_KEY_PATH=./secrets/AuthKey_PLACEHOLDER.p8
APP_STORE_ENVIRONMENT=Sandbox

# --- Observability (Stage 1+; see ADR-0003/0007) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
